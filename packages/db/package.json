{
  "name": "@kanji-learn/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed:kanji": "tsx src/seeds/seed-kanji.ts",
    "seed:kanji:fetch": "tsx src/seeds/seed-kanji-fetch.ts",
    "seed:kanjidic2": "tsx src/seeds/import-kanjidic2.ts",
    "seed:mnemonics": "tsx src/seeds/seed-mnemonics.ts",
    "seed:vocab": "tsx src/seeds/enrich-vocab.ts",
    "seed": "pnpm seed:kanji && pnpm seed:kanjidic2 && pnpm seed:mnemonics"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "drizzle-orm": "^0.31.0",
    "fast-xml-parser": "^5.5.9",
    "postgres": "^3.4.3"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.22.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
