# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
web-build/
*.js.map
*.tsbuildinfo

# ── Expo ──────────────────────────────────────────────────────────────────────
.expo/
expo-env.d.ts

# ── Environment files (never commit secrets) ──────────────────────────────────
.env
.env.local
.env.*.local

# ── Turbo cache ───────────────────────────────────────────────────────────────
.turbo/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*

# ── Native build artifacts ────────────────────────────────────────────────────
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/

# ── Xcode (apps/watch/) ───────────────────────────────────────────────────────
apps/watch/**/*.xcuserstate
apps/watch/**/xcuserdata/
apps/watch/**/DerivedData/
