# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
web-build/
*.js.map
*.tsbuildinfo

# ── Expo ──────────────────────────────────────────────────────────────────────
.expo/
expo-env.d.ts

# ── Environment files (never commit secrets) ──────────────────────────────────
.env
.env.local
.env.*.local
# Ad-hoc local env files for prod read-only claude_readonly audits, etc.
# NEVER commit — contain database credentials.
.env.prod.readonly
.env.*.readonly

# ── Turbo cache ───────────────────────────────────────────────────────────────
.turbo/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*

# ── Native build artifacts ────────────────────────────────────────────────────
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
# Allow the Watch distribution profile committed alongside its plugin
!apps/mobile/plugins/withWatchApp/watch-profile.mobileprovision

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
.env.test

# ── Xcode (apps/watch/) ───────────────────────────────────────────────────────
apps/watch/**/*.xcuserstate
apps/watch/**/xcuserdata/
apps/watch/**/DerivedData/
apps/watch/**/*.xccheckout
apps/watch/**/*.moved-aside
apps/watch/**/build/
