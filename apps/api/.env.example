# Copy to .env and fill in values

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Supabase — from your project dashboard → Settings → API
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-min-32-chars
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Optional
CORS_ORIGIN=http://localhost:8081
LOG_LEVEL=info

# ── Kanji Buddy LLM router ─────────────────────────────────────────────
# Tier 2 providers (free-tier fast path). Leave blank to force fall-
# through to tier 3 / failure — providers self-report unavailable when
# their key is missing.
GROQ_API_KEY=
GEMINI_API_KEY=

# Per-user daily caps enforced by the rate limiter.
BUDDY_TIER2_DAILY_CAP_PER_USER=50
BUDDY_TIER3_DAILY_CAP_PER_USER=5

# Which provider the router tries first / second for tier 2 calls.
LLM_PRIMARY_TIER2_PROVIDER=groq
LLM_SECONDARY_TIER2_PROVIDER=gemini
