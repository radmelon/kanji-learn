<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Invitation Declined</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: #f4f4f8;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      max-width: 420px;
      width: 100%;
      overflow: hidden;
      text-align: center;
    }
    .card-header {
      background: #0F0F1A;
      padding: 20px 28px;
    }
    .card-header h1 {
      color: #F0F0F5;
      font-size: 18px;
      font-weight: 700;
    }
    .card-body {
      padding: 40px 28px;
    }
    .icon {
      font-size: 48px;
      margin-bottom: 16px;
    }
    h2 {
      font-size: 22px;
      color: #0F0F1A;
      margin-bottom: 12px;
    }
    p {
      color: #666;
      font-size: 14px;
      line-height: 1.6;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="card-header">
      <h1>Kanji Buddy</h1>
    </div>
    <div class="card-body">
      <div class="icon">👋</div>
      <h2>Invitation Declined</h2>
      <p>You have declined the invitation to view this learning report. No data was shared. You can close this page.</p>
    </div>
  </div>
</body>
</html>
