# Copy to apps/api/.env.test and fill in values.
TEST_DATABASE_URL=postgres://kanji:kanji@localhost:5433/kanji_buddy_test
# test/setup.ts copies TEST_DATABASE_URL → DATABASE_URL so env.ts validates.
# Set this explicitly to the same value so buildServer() in tests like
# phase0-smoke can parse the env before setup.ts has a chance to run.
DATABASE_URL=postgres://kanji:kanji@localhost:5433/kanji_buddy_test
SUPABASE_JWT_SECRET=test-jwt-secret-at-least-32-characters-long-stub
SUPABASE_SERVICE_ROLE_KEY=test-service-role-key
GROQ_API_KEY=test-fake-key
GEMINI_API_KEY=test-fake-key
# env.ts enforces the sk-ant- prefix; stub value below passes zod parsing.
ANTHROPIC_API_KEY=sk-ant-test-fake-key
LLM_PRIMARY_TIER2_PROVIDER=groq
BUDDY_TIER2_DAILY_CAP_PER_USER=50
BUDDY_TIER3_DAILY_CAP_PER_USER=2
