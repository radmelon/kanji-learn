{
  "expo": {
    "name": "Kanji Learn",
    "slug": "kanji-learn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kanjilearn",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rdennis.kanjilearn2",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        },
        "NSLocalNetworkUsageDescription": "Allow Kanji Learn to connect to a local development server.",
        "NSBonjourServices": [
          "_react-native-packager._tcp"
        ],
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow Kanji Learn to use the microphone for reading evaluation.",
        "NSPhotoLibraryUsageDescription": "Allow Kanji Learn to attach photos to your mnemonics.",
        "NSLocationWhenInUseUsageDescription": "Allow Kanji Learn to tag mnemonics with the place where you learned them.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "107"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.kanjilearn.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "./plugins/withXcode16Fix",
      "./plugins/withWatchApp",
      "./plugins/withWatchConnectivity",
      "expo-router",
      "expo-web-browser",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Kanji Learn to use the microphone for reading evaluation."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6C63FF",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Kanji Learn to attach photos to your mnemonics."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Kanji Learn to tag mnemonics with the place where you learned them."
        }
      ]
    ],
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#6C63FF"
    },
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": false,
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0c1f17c5-e267-44ce-84cb-3ad467d6f9fa"
      }
    },
    "owner": "radmelon"
  }
}
